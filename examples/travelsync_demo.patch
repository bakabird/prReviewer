+import { NextResponse } from "next/server";
+import { createServerClient } from "@/lib/supabaseServer";
+import { checkTripAccess } from "@/lib/tripAccess";
+import { createClient } from "@supabase/supabase-js";
+
+export async function GET(
+  _req: Request,
+  { params }: { params: Promise<{ tripId: string }> },
+) {
+  try {
+    const supabase = await createServerClient();
+    const {
+      data: { user },
+    } = await supabase.auth.getUser();
+    if (!user) {
+      return NextResponse.json({ error: "Unauthorized" }, { status: 401 });
+    }
+
+    const { tripId } = await params;
+    const access = await checkTripAccess(supabase, tripId, user.id);
+    if (!access.hasAccess) {
+      return NextResponse.json({ error: "Forbidden" }, { status: 403 });
+    }
+
+    const { data: options, error } = await supabase
+      .from("trip_options")
+      .select("id, type, status, metadata")
+      .eq("trip_id", tripId);
+
+    if (error) {
+      console.error(error);
+      return NextResponse.json(
+        { error: "Failed to load options" },
+        { status: 500 },
+      );
+    }
+
+    const booked = (options || []).find((opt: any) => {
+      const status = opt.status || opt.metadata?.status;
+      return (
+        (opt.type === "flight" || opt.type === "housing") &&
+        status === "booked" &&
+        (opt.metadata?.booking_receipt_path || opt.metadata?.booking_receipt_url)
+      );
+    });
+
+    if (!booked) {
+      return NextResponse.json({ receipt_url: null });
+    }
+
+    const receiptUrl = booked.metadata?.booking_receipt_url || null;
+    const receiptPath = booked.metadata?.booking_receipt_path || null;
+    const confirmedBy = booked.metadata?.booking_confirmed_by || null;
+    const confirmedAt = booked.metadata?.booking_confirmed_at || null;
+
+    let confirmedByName: string | null = null;
+    if (confirmedBy) {
+      const { data: profile } = await supabase
+        .from("profiles")
+        .select("full_name")
+        .eq("id", confirmedBy)
+        .single();
+      confirmedByName = profile?.full_name || null;
+    }
+
+    if (!receiptPath) {
+      return NextResponse.json({
+        receipt_url: receiptUrl,
+        confirmed_by: confirmedByName,
+        confirmed_at: confirmedAt,
+      });
+    }
+
+    const serviceUrl = process.env.NEXT_PUBLIC_SUPABASE_URL;
+    const serviceKey = process.env.SUPABASE_SERVICE_ROLE_KEY;
+    const admin =
+      serviceUrl && serviceKey ? createClient(serviceUrl, serviceKey) : null;
+    const storageClient = admin ? admin.storage : supabase.storage;
+
+    const { data } = await storageClient
+      .from("trip-receipts")
+      .createSignedUrl(receiptPath, 60 * 60);
+
+    return NextResponse.json({
+      receipt_url: data?.signedUrl || receiptUrl,
+      confirmed_by: confirmedByName,
+      confirmed_at: confirmedAt,
+    });
+  } catch (err) {
+    console.error(err);
+    return NextResponse.json(
+      { error: "Failed to load booking receipt" },
+      { status: 500 },
+    );
+  }
+}
diff --git a/trip-sync/src/app/api/trips/[tripId]/confirm-booking/route.ts b/trip-sync/src/app/api/trips/[tripId]/confirm-booking/route.ts
