@@ -0,0 +1,105 @@
+import { NextResponse } from "next/server";
+import { createServerClient } from "@/lib/supabaseServer";
+import { checkTripAccess } from "@/lib/tripAccess";
+
+export async function POST(
+  req: Request,
+  { params }: { params: Promise<{ tripId: string }> },
+) {
+  try {
+    const supabase = await createServerClient();
+    const {
+      data: { user },
+    } = await supabase.auth.getUser();
+
+    if (!user) {
+      return NextResponse.json({ error: "Unauthorized" }, { status: 401 });
+    }
+
+    const { tripId } = await params;
+    const access = await checkTripAccess(supabase, tripId, user.id);
+    if (!access.hasAccess) {
+      return NextResponse.json({ error: "Forbidden" }, { status: 403 });
+    }
+
+    const body = await req.json().catch(() => ({}));
+    const bookingReceiptPath = body?.booking_receipt_path || null;
+    const bookingReceiptUrl = body?.booking_receipt_url || null;
+
+    const { data: options, error } = await supabase
+      .from("trip_options")
+      .select("id, type, status, metadata")
+      .eq("trip_id", tripId);
+
+    if (error) {
+      console.error(error);
+      return NextResponse.json(
+        { error: "Failed to load options" },
+        { status: 500 },
+      );
+    }
+
+    const isBooked = (opt: any) =>
+      opt.status === "booked" || opt.metadata?.status === "booked";
+
+    const bookedOptions = (options || []).filter(
+      (opt: any) => (opt.type === "flight" || opt.type === "housing") && isBooked(opt),
+    );
+
+    if (bookedOptions.length === 0) {
+      return NextResponse.json(
+        { error: "No booked flight or housing to confirm" },
+        { status: 400 },
+      );
+    }
+
+    const now = new Date().toISOString();
+    const updates = bookedOptions.map((opt: any) => ({
+      id: opt.id,
+      metadata: {
+        ...(opt.metadata || {}),
+        booking_confirmed_at: now,
+        booking_confirmed_by: user.id,
+        booking_receipt_path: bookingReceiptPath,
+        booking_receipt_url: bookingReceiptUrl,
+      },
+    }));
+
+    const { error: updateError } = await supabase
+      .from("trip_options")
+      .upsert(updates, { onConflict: "id" });
+
+    if (updateError) {
+      console.error(updateError);
+      return NextResponse.json(
+        { error: "Failed to confirm booking" },
+        { status: 500 },
+      );
+    }
+
+    const title = "Booking confirmed";
+    const message = bookingReceiptPath || bookingReceiptUrl
+      ? "Booking confirmed and receipt uploaded."
+      : "Your group confirmed bookings for this trip.";
+    const url = `/trips/${tripId}`;
+    await supabase.from("trip_notifications").insert({
+      trip_id: tripId,
+      type: "booking_confirmed",
+      title,
+      message,
+      url,
+      metadata: {
+        confirmed_at: now,
+      },
+      recorded_at: now,
+    });
+
+    return NextResponse.json({ success: true });
+  } catch (err) {
+    console.error(err);
+    return NextResponse.json(
+      { error: "Failed to confirm booking" },
+      { status: 500 },
+    );
+  }
+}
