+import { NextResponse } from "next/server";
+import { createServerClient } from "@/lib/supabaseServer";
+import { checkTripAccess } from "@/lib/tripAccess";
+
+export async function POST(
+  _req: Request,
+  { params }: { params: Promise<{ tripId: string }> },
+) {
+  try {
+    const supabase = await createServerClient();
+    const {
+      data: { user },
+    } = await supabase.auth.getUser();
+    if (!user) {
+      return NextResponse.json({ error: "Unauthorized" }, { status: 401 });
+    }
+
+    const { tripId } = await params;
+    const access = await checkTripAccess(supabase, tripId, user.id);
+    if (!access.hasAccess) {
+      return NextResponse.json({ error: "Forbidden" }, { status: 403 });
+    }
+
+    const { data: options, error } = await supabase
+      .from("trip_options")
+      .select("id, type, status, metadata")
+      .eq("trip_id", tripId);
+
+    if (error) {
+      console.error(error);
+      return NextResponse.json({ error: "Failed to load options" }, { status: 500 });
+    }
+
+    const isFinal = (opt: any) =>
+      opt.status === "final" || opt.metadata?.status === "final";
+
+    const finalOptions = (options || []).filter(
+      (opt: any) => (opt.type === "flight" || opt.type === "housing") && isFinal(opt),
+    );
+
+    if (finalOptions.length === 0) {
+      return NextResponse.json(
+        { error: "No final flight or housing selected" },
+        { status: 400 },
+      );
+    }
+
+    const updates = finalOptions.map((opt: any) => ({
+      id: opt.id,
+      status: "booked",
+      metadata: {
+        ...(opt.metadata || {}),
+        status: "booked",
+        booked_at: new Date().toISOString(),
+      },
+    }));
+
+    const { error: updateError } = await supabase
+      .from("trip_options")
+      .upsert(updates, { onConflict: "id" });
+
+    if (updateError) {
+      console.error(updateError);
+      return NextResponse.json({ error: "Failed to mark booked" }, { status: 500 });
+    }
+
+    return NextResponse.json({ success: true });
+  } catch (err) {
+    console.error(err);
+    return NextResponse.json({ error: "Failed to book" }, { status: 500 });
+  }
+}
